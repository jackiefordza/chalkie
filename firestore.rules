rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && me().role == 'admin';
    }

    function isCaptainOrVC() {
      return isSignedIn() && me().role in ['captain', 'viceCaptain'];
    }

    // ── leagues ───────────────────────────────────────────────────────────
    match /leagues/{leagueId} {
      allow read: if isSignedIn() && me().leagueId == leagueId;
      allow write: if isAdmin() && me().leagueId == leagueId;
    }

    // ── seasons ───────────────────────────────────────────────────────────
    match /seasons/{seasonId} {
      allow read: if isSignedIn() && me().leagueId == resource.data.leagueId;
      allow create: if isAdmin() && me().leagueId == request.resource.data.leagueId;
      allow update, delete: if isAdmin() && me().leagueId == resource.data.leagueId;
    }

    // ── divisions ─────────────────────────────────────────────────────────
    match /divisions/{divisionId} {
      allow read: if isSignedIn() && me().leagueId == resource.data.leagueId;
      allow create: if isAdmin() && me().leagueId == request.resource.data.leagueId;
      allow update, delete: if isAdmin() && me().leagueId == resource.data.leagueId;
    }

    // ── teams ─────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      allow read: if isSignedIn() && me().leagueId == resource.data.leagueId;
      allow create: if isAdmin() && me().leagueId == request.resource.data.leagueId;
      allow update, delete: if isAdmin() && me().leagueId == resource.data.leagueId;
    }

    // ── players ───────────────────────────────────────────────────────────
    match /players/{playerId} {
      allow read: if isSignedIn() && me().leagueId == resource.data.leagueId;

      allow create: if isCaptainOrVC()
        && me().teamId == request.resource.data.teamId
        && request.resource.data.claimedByUserId == null;

      allow update: if
        // Admin full access
        (isAdmin() && me().leagueId == resource.data.leagueId)
        // Captain/VC edits player details but cannot touch claimedByUserId
        || (isCaptainOrVC()
            && me().teamId == resource.data.teamId
            && resource.data.claimedByUserId == request.resource.data.claimedByUserId)
        // Any signed-in user can claim an unclaimed record — sets claimedByUserId to own UID, once only
        || (isSignedIn()
            && resource.data.claimedByUserId == null
            && request.resource.data.claimedByUserId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['claimedByUserId', 'claimedAt']));

      allow delete: if
        (isAdmin() && me().leagueId == resource.data.leagueId)
        || (isCaptainOrVC()
            && me().teamId == resource.data.teamId
            && resource.data.claimedByUserId == null);
    }

    // ── users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // First sign-up: user creates their own document with role=pending
      allow create: if request.auth.uid == userId
        && request.resource.data.role == 'pending'
        && request.resource.data.leagueId == null
        && request.resource.data.teamId == null
        && request.resource.data.playerId == null;

      // User can update display name only; role/leagueId/teamId changed only by Cloud Functions
      allow update: if
        (request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.leagueId == resource.data.leagueId
          && request.resource.data.teamId == resource.data.teamId
          && request.resource.data.divisionId == resource.data.divisionId
          && request.resource.data.playerId == resource.data.playerId)
        || isAdmin();
    }

    // ── joinCodes ─────────────────────────────────────────────────────────
    match /joinCodes/{code} {
      // get by exact ID only — the code string is the credential
      allow get: if isSignedIn();
      allow list: if isAdmin();

      allow create: if
        (isAdmin() && me().leagueId == request.resource.data.leagueId)
        || (isCaptainOrVC()
            && request.resource.data.role == 'viceCaptain'
            && me().teamId == request.resource.data.teamId);

      // Claiming user marks code as used — only usedByUserId and usedAt may change
      allow update: if isSignedIn()
        && resource.data.usedByUserId == null
        && request.resource.data.usedByUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usedByUserId', 'usedAt']);
    }

    // ── matches ───────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isSignedIn() && me().leagueId == resource.data.leagueId;
      allow create: if isAdmin() && me().leagueId == request.resource.data.leagueId;
      allow update, delete: if isAdmin() && me().leagueId == resource.data.leagueId;

      match /submissions/{submissionId} {
        function matchData() {
          return get(/databases/$(database)/documents/matches/$(matchId)).data;
        }

        allow read: if isSignedIn() && (
          isAdmin()
          || me().teamId == matchData().homeTeamId
          || me().teamId == matchData().awayTeamId
        );

        allow create, update: if isCaptainOrVC()
          && me().teamId == request.resource.data.submittedByTeamId
          && matchData().status != 'confirmed';
      }
    }

    // ── divisionTables ────────────────────────────────────────────────────
    match /divisionTables/{tableId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only (admin SDK bypasses rules)
    }

    // ── playerSeasonStats ─────────────────────────────────────────────────
    match /playerSeasonStats/{statsId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only
    }

    // ── fineDefinitions ───────────────────────────────────────────────────
    match /fineDefinitions/{fineDefId} {
      allow read: if isSignedIn() && me().teamId == resource.data.teamId;
      allow create: if isCaptainOrVC() && me().teamId == request.resource.data.teamId;
      allow update, delete: if isCaptainOrVC() && me().teamId == resource.data.teamId;
    }

    // ── fineEntries ───────────────────────────────────────────────────────
    match /fineEntries/{fineEntryId} {
      allow read: if isSignedIn() && me().teamId == resource.data.teamId;
      allow create: if isCaptainOrVC() && me().teamId == request.resource.data.teamId;
      allow update, delete: if isCaptainOrVC() && me().teamId == resource.data.teamId;
    }
  }
}
